#: core/announcements.py:135
msgid "Filter change"
msgstr "फ़िल्टर बदलाव"

#: core/announcements.py:136
msgid "Announce the applied article filter (Ctrl+1 to Ctrl+6)."
msgstr "लागू किया गया लेख फ़िल्टर घोषित करें (Ctrl+1 से Ctrl+6)।"

