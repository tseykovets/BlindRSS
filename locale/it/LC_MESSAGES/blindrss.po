#: core/announcements.py:147
msgid "Media and chapter navigation"
msgstr "Navigazione tra media e capitoli"

#: core/announcements.py:148
msgid "Announce the item or chapter when moving to the next/previous one."
msgstr ""
"Annuncia l'elemento o il capitolo quando si passa al successivo/precedente."

#: core/announcements.py:149
msgid "Other notifications"
msgstr "Altre notifiche"

#: core/announcements.py:150
msgid "Announce other significant interface changes and notifications."
