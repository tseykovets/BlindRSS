msgid_plural "Imported {count} cookies from {browser}."
msgstr[0] "Zaimportowano {count} plik cookie z {browser}."
msgstr[1] "Zaimportowano {count} pliki cookie z {browser}."
msgstr[2] "Zaimportowano {count} plików cookie z {browser}."

