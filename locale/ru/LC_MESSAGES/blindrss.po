#: core/announcements.py:135
msgid "Filter change"
msgstr "Изменение фильтра"

#: core/announcements.py:136
msgid "Announce the applied article filter (Ctrl+1 to Ctrl+6)."
msgstr "Объявлять применённый фильтр статей (с Ctrl+1 по Ctrl+6)."

#: core/announcements.py:137
msgid "Read/unread status change"
msgstr "Изменение статуса прочитано/непрочитано"

#: core/announcements.py:138
msgid "Announce the new status when toggling read/unread (Backspace)."
msgstr ""
"Объявлять новый статус при переключении прочитано/непрочитано (Backspace)."

#: core/announcements.py:139
msgid "Start update"
msgstr "Запуск обновления"

#: core/announcements.py:140
msgid "Announce when a feed refresh is started (F5)."
msgstr "Объявлять, когда начинается обновление каналов (F5)."

#: core/announcements.py:141
msgid "Stop update"
msgstr "Остановка обновления"

#: core/announcements.py:142
msgid "Announce when a feed refresh is stopped (Shift+F5)."
msgstr "Объявлять, когда останавливается обновление каналов (Shift+F5)."

#: core/announcements.py:143
msgid "Favorites change"
msgstr "Изменение избранного"

#: core/announcements.py:144
msgid ""
"Announce when an article is added to or removed from favorites (Ctrl+D)."
msgstr ""
"Объявлять, когда статья добавляется или удаляется из избранного (Ctrl+D)."

#: core/announcements.py:145
msgid "Playback speed change"
msgstr "Изменение скорости воспроизведения"

#: core/announcements.py:146
msgid "Announce the current playback speed when it is changed by keyboard."
msgstr ""
"Объявлять текущую скорость воспроизведения, когда она изменяется при помощи "
"клавиатуры."

#: core/announcements.py:147
msgid "Media and chapter navigation"
msgstr "Навигация по мультимедиа и тайм-кодам"

#: core/announcements.py:148
msgid "Announce the item or chapter when moving to the next/previous one."
msgstr ""
"Объявлять элемент или тайм-код при  переходе к следующему/предыдущему."

#: core/announcements.py:149
msgid "Other notifications"
msgstr "Другие уведомления"

#: core/announcements.py:150
msgid "Announce other significant interface changes and notifications."
msgstr "Объявлять другие существенные изменения интерфейса  и уведомления."

#: core/announcements.py:151
msgid "None"
msgstr "Нет"

