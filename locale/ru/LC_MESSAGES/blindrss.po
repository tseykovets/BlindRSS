msgstr "Объявлять заголовки (\"Заголовок уровня 2:\" перед каждым заголовком)"

#: gui/dialogs.py:1173
msgid "Mark list items with bullets and numbers"
msgstr "Обозначать элементы списков маркерами и числами"

#: gui/dialogs.py:1179
