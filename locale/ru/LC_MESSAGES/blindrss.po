#: core/announcements.py:129
msgid "Filter change"
msgstr "Изменение фильтра"

#: core/announcements.py:130
msgid "Announce the applied article filter (Ctrl+1 to Ctrl+6)."
msgstr "Объявлять применённый фильтр статей (с Ctrl+1 по Ctrl+6)."

#: core/announcements.py:131
msgid "Read/unread status change"
msgstr "Изменение статуса прочитано/непрочитано"

#: core/announcements.py:132
msgid "Announce the new status when toggling read/unread (Backspace)."
msgstr ""
"Объявлять новый статус при переключении прочитано/непрочитано (Backspace)."

#: core/announcements.py:133
msgid "Start update"
msgstr "Запуск обновления"

#: core/announcements.py:134
msgid "Announce when a feed refresh is started (F5)."
msgstr "Объявлять, когда начинается обновление каналов (F5)."

